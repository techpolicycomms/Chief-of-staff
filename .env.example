# Copy to .env and fill in. Any script whose env vars are missing becomes
# a no-op, so you can start with just the integrations you need.

# Anthropic (for scheduled scripts that call Claude directly)
ANTHROPIC_API_KEY=

# Claude model used by scheduled scripts
CLAUDE_MODEL=claude-opus-4-6

# Todoist
TODOIST_API_TOKEN=

# Granola (or any meeting note-taker with an API)
GRANOLA_API_KEY=
GRANOLA_BASE_URL=https://api.granola.ai

# Gmail / Google Calendar — path to the OAuth credentials JSON
GOOGLE_OAUTH_CREDENTIALS=config/secrets/google_oauth.json
GMAIL_ACCOUNTS=personal,work

# WhatsApp delivery — Twilio example
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+10000000000

# Repository root — used by cron so scripts can locate memory/
CHIEF_OF_STAFF_HOME=/absolute/path/to/chief-of-staff
